# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'NavAideShell' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # maplibre-react-native injects the Swift package product dependency (MapLibre)
    # into the pod and app targets during CocoaPods post-install.
    $MLRN.post_install(installer)

    # llama.rn 0.5.7 pins -std=c++17 via its podspec, but React Native 0.85's
    # ReactCommon bridging headers use C++20 `requires` constraints. CocoaPods
    # writes OTHER_CPLUSPLUSFLAGS into the llama-rn xcconfig files, so patch
    # those directly to replace -std=c++17 with -std=c++20.
    llama_xcconfig_dir = File.join(installer.sandbox.target_support_files_root, 'llama-rn')
    if Dir.exist?(llama_xcconfig_dir)
      Dir.glob(File.join(llama_xcconfig_dir, '*.xcconfig')).each do |xcconfig_path|
        contents = File.read(xcconfig_path)
        patched = contents.gsub('-std=c++17', '-std=c++20')
        File.write(xcconfig_path, patched) if patched != contents
      end
    end
  end
end
