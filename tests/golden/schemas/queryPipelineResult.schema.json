{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "QueryPipelineGoldenResult",
    "type": "object",
    "required": [
        "status",
        "extraction",
        "disruptions",
        "rendered"
    ],
    "properties": {
        "status": {
            "type": "string",
            "enum": [
                "complete",
                "needs_disambiguation",
                "unresolved"
            ]
        },
        "fastPathHints": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "extraction": {
            "type": "object",
            "required": [
                "detectedLanguage",
                "intent",
                "origin",
                "destination",
                "poiQuery",
                "requiresDisambiguation",
                "rawQuery"
            ]
        },
        "disruptions": {
            "type": "array"
        },
        "rendered": {
            "type": [
                "object",
                "null"
            ]
        },
        "route": {
            "type": [
                "object",
                "null"
            ]
        },
        "walking": {
            "type": [
                "object",
                "null"
            ]
        }
    }
}