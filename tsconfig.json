{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "jsx": "react-jsx",
        "lib": [
            "ES2022"
        ],
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "rootDir": ".",
        "outDir": "dist",
        "types": [
            "node",
            "react",
            "react-native"
        ]
    },
    "include": [
        "App.tsx",
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "scripts/**/*.ts",
        "src/types/**/*.d.ts"
    ]
}