{
    "name": "nav-aide",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "android": "react-native run-android",
        "ios": "react-native run-ios",
        "ios:release": "react-native run-ios --mode Release",
        "ios:device-release": "react-native run-ios --mode Release --udid",
        "start": "react-native start",
        "bundle:android": "react-native bundle --entry-file index.js --platform android --dev false --bundle-output .artifacts/index.android.bundle --assets-dest .artifacts/android",
        "bundle:ios": "react-native bundle --entry-file index.js --platform ios --dev false --bundle-output .artifacts/main.jsbundle --assets-dest .artifacts",
        "build": "tsc -p tsconfig.json",
        "test": "tsx --test tests/**/*.test.ts tests/**/**/*.test.ts",
        "stage2:sql": "node scripts/data-pipeline/build-tube-graph.js && node scripts/data-pipeline/generate-bus-routes.js && node scripts/data-pipeline/generate-pois-db.js && node scripts/data-pipeline/generate-location-aliases-db.js",
        "stage2:data": "npm run stage2:sql",
        "stage2:assemble": "node scripts/data-pipeline/assemble-sqlite-dbs.js",
        "stage2:validate": "tsx scripts/data-pipeline/validate-sqlite-dbs.ts",
        "stage2:assets": "npm run stage2:sql && npm run stage2:assemble && npm run stage2:validate",
        "stage2:test": "npm run stage2:assets && npm run build && npm test",
        "phase3a:verify": "npm run build && npm test && npm run bundle:ios && npm run bundle:android"
    },
    "dependencies": {
        "@maplibre/maplibre-react-native": "^10.1.34",
        "@react-native-voice/voice": "^3.2.4",
        "@react-navigation/bottom-tabs": "^7.4.2",
        "@react-navigation/native": "^7.1.14",
        "fuse.js": "^7.1.0",
        "llama.rn": "^0.5.7",
        "react": "19.2.3",
        "react-native": "0.85.0",
        "react-native-fs": "^2.20.0",
        "react-native-gesture-handler": "^2.28.0",
        "react-native-reanimated": "^4.1.3",
        "react-native-safe-area-context": "^5.5.2",
        "react-native-screens": "^4.16.0",
        "react-native-sqlite-storage": "^6.0.1",
        "react-native-tts": "^4.1.1",
        "react-native-worklets": "^0.8.1"
    },
    "devDependencies": {
        "@babel/core": "^7.25.2",
        "@babel/preset-env": "^7.25.3",
        "@babel/runtime": "^7.25.0",
        "@react-native-community/cli": "20.1.0",
        "@react-native-community/cli-platform-android": "20.1.0",
        "@react-native-community/cli-platform-ios": "20.1.0",
        "@react-native/babel-preset": "0.85.0",
        "@react-native/metro-config": "0.85.0",
        "@types/node": "^20.14.2",
        "@types/react": "^19.2.0",
        "tsx": "^4.15.7",
        "typescript": "^5.8.3"
    },
    "engines": {
        "node": ">=20"
    }
}
